#!/usr/bin/env bash
set -euo pipefail

# ClickHouse - Read-only HTTP client for the yulai event-tracking store.
# Talks to ClickHouse's HTTP interface with curl (the native protocol is not
# exposed). All connection details live in a local .env (never committed).

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

cmd_help() {
    cat << EOF
${BLUE}ClickHouse - Read-only HTTP client (yulai event store)${NC}

${YELLOW}Usage:${NC}
  ./clickhouse <command> [arguments]

${YELLOW}Commands:${NC}
  ${GREEN}test${NC}                    Test the connection (SELECT 1)
  ${GREEN}query${NC} <sql> [format]    Run a read-only query (formats: pretty, tsv, json, csv)
  ${GREEN}tables${NC}                  List tables in the database
  ${GREEN}describe${NC} <table>        Show a table's columns and types
  ${GREEN}schema${NC}                  Describe the main events_raw table
  ${GREEN}tenants${NC}                 List distinct tenants present in the data
  ${GREEN}help${NC}                    Show this help

${YELLOW}Examples:${NC}
  ./clickhouse test
  ./clickhouse schema
  ./clickhouse tenants
  ./clickhouse query "SELECT count() FROM events_raw WHERE tenant='app.sytex.io'"
  ./clickhouse query "SELECT path, count() c FROM events_raw WHERE tenant='app.sytex.io' AND kind='request' GROUP BY path ORDER BY c DESC LIMIT 20"
  ./clickhouse query "SELECT email, count() FROM events_raw WHERE tenant='app.sytex.io' GROUP BY email ORDER BY 2 DESC LIMIT 10" tsv

${YELLOW}Notes:${NC}
  - Only read queries are allowed (SELECT / WITH / SHOW / DESCRIBE / EXPLAIN).
  - Always filter by tenant (production data is tenant='app.sytex.io').
  - See SKILL.md for the schema and analysis guidance.
EOF
}

if [[ "${1:-}" == "help" ]] || [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]] || [[ $# -eq 0 ]]; then
    cmd_help
    exit 0
fi

# Load configuration
if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
else
    echo -e "${RED}Error: .env file not found at $ENV_FILE${NC}"
    echo "Run the installer to configure the ClickHouse connection."
    exit 1
fi

ENDPOINT="${CLICKHOUSE_QUERY_ENDPOINT:-}"
HOST_HEADER="${CLICKHOUSE_QUERY_HOST_HEADER:-}"
CH_USER="${CLICKHOUSE_QUERY_USER:-default}"
CH_PASSWORD="${CLICKHOUSE_QUERY_PASSWORD:-}"
DEFAULT_TENANT="${CLICKHOUSE_QUERY_TENANT:-app.sytex.io}"

if [[ -z "$ENDPOINT" ]]; then
    echo -e "${RED}Error: CLICKHOUSE_QUERY_ENDPOINT is not set in .env${NC}"
    echo "Run the installer to configure the ClickHouse connection."
    exit 1
fi

if ! command -v curl &> /dev/null; then
    echo -e "${RED}Error: curl not found${NC}"
    exit 1
fi

# Map friendly format names to ClickHouse output formats
ch_format() {
    case "${1:-pretty}" in
        pretty|table) echo "PrettyCompact" ;;
        tsv)          echo "TSVWithNames" ;;
        json)         echo "JSON" ;;
        csv)          echo "CSVWithNames" ;;
        *)            echo "PrettyCompact" ;;
    esac
}

# Core: send SQL to the HTTP interface. Uses default_format so callers need not
# append FORMAT (an explicit FORMAT in the SQL still wins).
run_query() {
    local query="$1"
    local fmt="${2:-pretty}"
    local default_format
    default_format="$(ch_format "$fmt")"

    local curl_args=(
        -sS --fail-with-body -k
        "${ENDPOINT}/?default_format=${default_format}"
        -H "X-ClickHouse-User: ${CH_USER}"
        -H "X-ClickHouse-Key: ${CH_PASSWORD}"
        --connect-timeout 10 --max-time 120
        --data-binary "$query"
    )
    [[ -n "$HOST_HEADER" ]] && curl_args+=(-H "Host: ${HOST_HEADER}")

    curl "${curl_args[@]}"
}

# Reject anything that is not a read-only statement.
assert_readonly() {
    local q="$1"
    # Strip leading whitespace / comments, lowercase the first keyword.
    local first
    first=$(echo "$q" | sed -e 's/^[[:space:]]*//' | grep -oiE '^(with|select|show|describe|desc|explain)' | head -1 || true)
    if [[ -z "$first" ]]; then
        echo -e "${RED}Error: only read-only queries are allowed (SELECT / WITH / SHOW / DESCRIBE / EXPLAIN).${NC}" >&2
        exit 1
    fi
    # Defense in depth: block obvious write/DDL keywords anywhere in the query.
    if echo "$q" | grep -iwE 'insert|alter|drop|truncate|create|rename|attach|detach|optimize|delete|update|grant|revoke|set ' > /dev/null; then
        echo -e "${RED}Error: query contains a forbidden (write/DDL) keyword. This skill is read-only.${NC}" >&2
        exit 1
    fi
}

cmd_test() {
    echo -e "${BLUE}Testing ClickHouse connection...${NC}"
    if run_query "SELECT 1 AS connection_test" pretty > /dev/null 2>&1; then
        echo -e "${GREEN}✓ Connection successful${NC}"
        echo -e "${BLUE}Endpoint: ${NC}$ENDPOINT"
        echo -e "${BLUE}User: ${NC}$CH_USER"
        [[ -n "$HOST_HEADER" ]] && echo -e "${BLUE}Host header: ${NC}$HOST_HEADER"
    else
        echo -e "${RED}✗ Connection failed${NC}"
        run_query "SELECT 1" pretty || true
        exit 1
    fi
}

cmd_query() {
    local query="${1:-}"
    local fmt="${2:-pretty}"
    if [[ -z "$query" ]]; then
        echo -e "${RED}Error: query required${NC}"
        echo "Usage: ./clickhouse query \"SELECT ...\" [pretty|tsv|json|csv]"
        exit 1
    fi
    assert_readonly "$query"
    run_query "$query" "$fmt"
}

cmd_tables() {
    run_query "SHOW TABLES" pretty
}

cmd_describe() {
    local table="${1:-}"
    if [[ -z "$table" ]]; then
        echo -e "${RED}Error: table name required${NC}"
        echo "Usage: ./clickhouse describe <table>"
        exit 1
    fi
    # Validate identifier (letters, digits, underscore only).
    if ! echo "$table" | grep -qE '^[A-Za-z0-9_]+$'; then
        echo -e "${RED}Error: invalid table name${NC}"
        exit 1
    fi
    run_query "DESCRIBE TABLE \`$table\`" pretty
}

cmd_schema() {
    run_query "DESCRIBE TABLE events_raw" pretty
}

cmd_tenants() {
    run_query "SELECT tenant, count() AS rows FROM events_raw GROUP BY tenant ORDER BY rows DESC" pretty
}

main() {
    local cmd="${1:-help}"
    shift || true
    case "$cmd" in
        test)               cmd_test ;;
        query|q)            cmd_query "$@" ;;
        tables|list)        cmd_tables ;;
        describe|desc)      cmd_describe "$@" ;;
        schema)             cmd_schema ;;
        tenants)            cmd_tenants ;;
        help|--help|-h)     cmd_help ;;
        *)
            echo -e "${RED}Error: Unknown command '$cmd'${NC}"
            echo "Run './clickhouse help' for usage."
            exit 1
            ;;
    esac
}

main "$@"
