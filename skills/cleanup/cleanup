#!/usr/bin/env bash
# cleanup — Disk space management for Kadmos instance
set -euo pipefail

PROJECTS_DIR="/home/ubuntu/projects"
BACK_DIR="$PROJECTS_DIR/back"
FRONT_DIR="$PROJECTS_DIR/front"
CLAUDE_DIR="/home/ubuntu/.claude"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

info()   { echo -e "${CYAN}▸${NC} $*"; }
ok()     { echo -e "${GREEN}✓${NC} $*"; }
warn()   { echo -e "${YELLOW}⚠${NC} $*"; }
err()    { echo -e "${RED}✗${NC} $*" >&2; }
header() { echo -e "\n${BOLD}── $* ──${NC}"; }

DRY_RUN=0
MAX_AGE=5

usage() {
  cat <<'EOF'
Usage: cleanup <command> [options]

Commands:
  status                Show disk usage breakdown
  auto                  Run all safe cleanups (cron-safe)
  worktrees [--max-age DAYS]  Clean old worktrees (default: 5 days)
  docker                Clean stopped containers + dangling images
  cache                 Clean npm, apt, Claude telemetry/debug/sessions
  logs                  Vacuum journal + remove rotated logs
  tmp                   Clean /tmp files older than 1 day
  test                  Verify skill works

Options:
  --dry-run, -n         Show what would be cleaned without doing it
  --max-age DAYS        Max worktree age in days (default: 5)
EOF
}

# ── Helpers ────────────────────────────────────────────────

disk_before() { df --output=used / | tail -1 | tr -d ' '; }

report_saved() {
  local before=$1
  local after
  after=$(disk_before)
  local saved_kb=$(( before - after ))
  if (( saved_kb > 1048576 )); then
    echo "$(( saved_kb / 1048576 )) GB"
  elif (( saved_kb > 1024 )); then
    echo "$(( saved_kb / 1024 )) MB"
  else
    echo "${saved_kb} KB"
  fi
}

# ── Status ─────────────────────────────────────────────────

cmd_status() {
  header "Disk Overview"
  df -h / | tail -1 | awk '{printf "  Total: %s  Used: %s (%s)  Free: %s\n", $2, $3, $5, $4}'

  header "Top Consumers"
  echo "  Category                     Size"
  echo "  ─────────────────────────────────────"

  local docker_size snap_size
  docker_size=$(docker system df 2>/dev/null | awk 'NR==2{print $4}') || docker_size="N/A"
  snap_size=$(set +o pipefail; du -sh /snap 2>/dev/null | cut -f1) || snap_size="N/A"

  printf "  %-30s %s\n" "Docker (images)" "$docker_size"
  printf "  %-30s %s\n" "Snap (/snap)" "$snap_size"

  for d in projects .rustup .local .claude .nvm .npm kadmos .cache .cargo mysql; do
    if [[ -d "/home/ubuntu/$d" ]]; then
      local sz
      sz=$(set +o pipefail; timeout 10 du -sh "/home/ubuntu/$d" 2>/dev/null | cut -f1) || sz="N/A"
      printf "  %-30s %s\n" "~/$d" "$sz"
    fi
  done

  header "Worktrees"
  local count=0
  for dir in "$BACK_DIR"/SYT-*/ "$FRONT_DIR"/SYT-*/; do
    [[ -d "$dir" ]] || continue
    local name age_days sz
    name=$(basename "$dir")
    local repo=$(basename "$(dirname "$dir")")
    local last_commit
    last_commit=$(git -C "$dir" log -1 --format="%ci" 2>/dev/null || echo "")
    if [[ -n "$last_commit" ]]; then
      age_days=$(( ($(date +%s) - $(date -d "$last_commit" +%s)) / 86400 ))
    else
      age_days="?"
    fi
    sz=$(du -sh "$dir" 2>/dev/null | cut -f1)
    printf "  %-45s %6s  %s days\n" "$repo/$name" "$sz" "$age_days"
    count=$((count + 1))
  done
  [[ $count -eq 0 ]] && echo "  (none)"

  header "Docker Containers"
  docker ps -a --format "  {{.Names}}  {{.Status}}" 2>/dev/null || echo "  (docker not available)"
}

# ── Worktree Cleanup ──────────────────────────────────────

cmd_worktrees() {
  header "Worktree Cleanup (max age: ${MAX_AGE} days)"
  local cleaned=0

  for repo_dir in "$BACK_DIR" "$FRONT_DIR"; do
    local master_dir="$repo_dir/master"
    [[ -d "$master_dir/.git" ]] || continue
    local repo_name
    repo_name=$(basename "$repo_dir")

    for wt_dir in "$repo_dir"/SYT-*/ "$repo_dir"/worktree-*/; do
      [[ -d "$wt_dir" ]] || continue
      local branch
      branch=$(basename "$wt_dir")
      local last_commit
      last_commit=$(git -C "$wt_dir" log -1 --format="%ci" 2>/dev/null || echo "")
      [[ -z "$last_commit" ]] && continue

      local age_days
      age_days=$(( ($(date +%s) - $(date -d "$last_commit" +%s)) / 86400 ))

      if (( age_days > MAX_AGE )); then
        local sz
        sz=$(du -sh "$wt_dir" 2>/dev/null | cut -f1)

        if [[ $DRY_RUN -eq 1 ]]; then
          info "[DRY RUN] Would remove $repo_name/$branch ($sz, ${age_days}d old)"
        else
          # Stop related Docker containers
          local containers
          containers=$(docker ps -a --format "{{.Names}}" 2>/dev/null | grep -i "${branch}" || true)
          if [[ -n "$containers" ]]; then
            while IFS= read -r cname; do
              info "Stopping container $cname..."
              docker stop "$cname" >/dev/null 2>&1 || true
              docker rm "$cname" >/dev/null 2>&1 || true
            done <<< "$containers"
          fi

          info "Removing $repo_name/$branch ($sz, ${age_days}d old)..."
          git -C "$master_dir" worktree remove --force "$wt_dir" 2>/dev/null || rm -rf "$wt_dir"
          cleaned=$((cleaned + 1))
        fi
      fi
    done

    git -C "$master_dir" worktree prune 2>/dev/null || true
  done

  if [[ $DRY_RUN -eq 0 ]]; then
    ok "Cleaned $cleaned worktree(s)"
  fi
}

# ── Docker Cleanup ─────────────────────────────────────────

cmd_docker() {
  header "Docker Cleanup"

  if [[ $DRY_RUN -eq 1 ]]; then
    local stopped
    stopped=$(docker ps -a --filter "status=exited" --format "{{.Names}}" 2>/dev/null | wc -l)
    info "[DRY RUN] Would remove $stopped stopped container(s) + dangling images/volumes"
    return
  fi

  # Remove stopped containers (except master-*)
  local stopped_containers
  stopped_containers=$(docker ps -a --filter "status=exited" --format "{{.Names}}" 2>/dev/null || true)
  local removed=0
  if [[ -n "$stopped_containers" ]]; then
    while IFS= read -r cname; do
      docker rm "$cname" >/dev/null 2>&1 && removed=$((removed + 1))
    done <<< "$stopped_containers"
  fi
  ok "Removed $removed stopped container(s)"

  # Prune dangling images and volumes
  docker image prune -f >/dev/null 2>&1 || true
  docker volume prune -f >/dev/null 2>&1 || true
  ok "Pruned dangling images and volumes"
}

# ── Cache Cleanup ──────────────────────────────────────────

cmd_cache() {
  header "Cache Cleanup"

  if [[ $DRY_RUN -eq 1 ]]; then
    info "[DRY RUN] Would clean: Claude telemetry/debug, old sessions, npm cache, apt cache"
    return
  fi

  # Claude telemetry and debug
  rm -rf "$CLAUDE_DIR/telemetry/"* "$CLAUDE_DIR/debug/"* 2>/dev/null || true
  ok "Claude telemetry + debug cleaned"

  # Claude old sessions (>30 days)
  find "$CLAUDE_DIR/projects/" -maxdepth 2 -type d -mtime +30 -exec rm -rf {} + 2>/dev/null || true
  ok "Claude sessions >30d cleaned"

  # npm cache
  npm cache clean --force >/dev/null 2>&1 || true
  ok "npm cache cleaned"

  # apt cache
  sudo apt-get clean >/dev/null 2>&1 || true
  ok "apt cache cleaned"

  # Snap saved snapshots
  local snap_ids
  snap_ids=$(sudo snap saved 2>/dev/null | tail -n +2 | awk '{print $1}' || true)
  if [[ -n "$snap_ids" ]]; then
    while IFS= read -r sid; do
      sudo snap forget "$sid" >/dev/null 2>&1 || true
    done <<< "$snap_ids"
    ok "Snap snapshots purged"
  fi
}

# ── Log Cleanup ────────────────────────────────────────────

cmd_logs() {
  header "Log Cleanup"

  if [[ $DRY_RUN -eq 1 ]]; then
    info "[DRY RUN] Would vacuum journal to 50MB + remove rotated logs"
    return
  fi

  sudo journalctl --vacuum-size=50M >/dev/null 2>&1 || true
  sudo find /var/log -name "*.gz" -delete 2>/dev/null || true
  sudo find /var/log -name "*.1" -delete 2>/dev/null || true
  ok "Logs cleaned (journal vacuumed to 50MB)"
}

# ── Tmp Cleanup ────────────────────────────────────────────

cmd_tmp() {
  header "Tmp Cleanup"

  if [[ $DRY_RUN -eq 1 ]]; then
    local tmp_size
    tmp_size=$(set +o pipefail; du -sh /tmp 2>/dev/null | cut -f1) || tmp_size="N/A"
    info "[DRY RUN] Would clean /tmp files >1 day (currently $tmp_size)"
    return
  fi

  find /tmp -maxdepth 1 -type f -mtime +1 -delete 2>/dev/null || true
  find /tmp -maxdepth 1 -type d -mtime +1 ! -name tmp ! -name "systemd-*" -exec rm -rf {} + 2>/dev/null || true
  ok "/tmp cleaned"
}

# ── Auto (all cleanups) ───────────────────────────────────

cmd_auto() {
  local before
  before=$(disk_before)

  echo "=== Kadmos Cleanup — $(date '+%Y-%m-%d %H:%M %Z') ==="

  cmd_worktrees
  cmd_docker
  cmd_cache
  cmd_logs
  cmd_tmp

  if [[ $DRY_RUN -eq 0 ]]; then
    local saved
    saved=$(report_saved "$before")
    header "Summary"
    ok "Recovered: $saved"
    df -h / | tail -1 | awk '{printf "  Disk now: %s used (%s), %s free\n", $3, $5, $4}'
  fi
}

# ── Test ───────────────────────────────────────────────────

cmd_test() {
  echo "cleanup skill OK — $(df -h / | tail -1 | awk '{print $5}') disk used"
}

# ── Main ───────────────────────────────────────────────────

COMMAND="${1:-}"
shift || true

# Parse remaining flags
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run|-n) DRY_RUN=1; shift ;;
    --max-age)    MAX_AGE="${2:-5}"; shift 2 ;;
    *) shift ;;
  esac
done

case "$COMMAND" in
  status)     cmd_status ;;
  auto)       cmd_auto ;;
  worktrees)  cmd_worktrees ;;
  docker)     cmd_docker ;;
  cache)      cmd_cache ;;
  logs)       cmd_logs ;;
  tmp)        cmd_tmp ;;
  test)       cmd_test ;;
  -h|--help)  usage ;;
  *)          usage; exit 1 ;;
esac
